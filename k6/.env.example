# K6 Load Testing Environment Configuration
# Copy this to .env.k6 and adjust values as needed

# Base URL untuk API testing
BASE_URL=http://localhost:5000

# API Version
API_VERSION=/api/v1

# Test scenario yang akan dijalankan
# Options: smoke, rampUp, spike, soak, stress, peakLoad
SCENARIO=smoke

# Test user credentials (uncomment jika ingin override)
# TEST_USER_EMAIL=princess28@gmail.com
# TEST_USER_PASSWORD=Customer@123

# Admin user credentials
# TEST_ADMIN_EMAIL=paultulod@pm.me
# TEST_ADMIN_PASSWORD=Admin@123

# Resto Admin credentials
# TEST_RESTO_ADMIN_EMAIL=Roderick@gmail.com
# TEST_RESTO_ADMIN_PASSWORD=RestoAdmin@123

# K6 Cloud token (jika ingin upload ke cloud)
# K6_CLOUD_TOKEN=your_token_here

# Output format (json, csv, influxdb, etc)
# K6_OUT=json=results.json

# Disable thresholds untuk testing
# K6_NO_THRESHOLDS=false
